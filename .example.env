# ---------------------------------------------------------
# SOFTMANIA CHAT-BOT : ENVIRONMENT CONFIGURATION
# ---------------------------------------------------------

# ==========================================
# 1. DATABASE CONNECTION STRINGS (REQUIRED)
# ==========================================
# NEON_DATABASE_URL: Connection string for Neon Postgres Serverless.
# Purpose: Houses the PGVector `document_chunks` table, `query_logs`, `chat_sessions`, and `portal_links`.
# IMPORTANT: Use the pooled connection string (usually ending with -pooler.neon.tech) for production concurrency.
NEON_DATABASE_URL="postgresql://user:password@endpoint-pooler.neon.tech/dbname"

# NEO4J_URI: The Bolt or Neo4j+s URI for the AuraDB / local Neo4j instance.
# Purpose: Used to store extracted entities and relationships mapping knowledge graphs.
NEO4J_URI="neo4j+s://endpoint.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your-strong-neo4j-password"

# ==========================================
# 2. AI MODEL CONFIGURATION (REQUIRED)
# ==========================================
# MISTRAL_API_KEY: Authentication key for Mistral AI platform.
# Purpose: Used when LOCAL_EMBEDDING_MODEL=false to generate text completions and semantic embeddings.
MISTRAL_API_KEY="sk-your-mistral-api-key"

# LOCAL_EMBEDDING_MODEL: Toggle between Cloud or Local embeddings.
# Purpose: Set to 'false' to use Mistral API, or 'true' to use local HuggingFace sentence-transformers.
# Note: Using local embeddings requires more RAM, but avoids network latency and API costs.
LOCAL_EMBEDDING_MODEL=false

# LLM_MAX_RETRIES / LLM_TIMEOUT: Safeguards against exponential cascading failures.
# Purpose: Under heavy load, limits prevent 'thundering herd' by failing fast instead of hanging.
LLM_MAX_RETRIES=3
LLM_TIMEOUT=15

# LLM_CONCURRENCY_LIMIT: Maximum simultaneous active LLM calls globally.
# Purpose: Acts as a global bulkhead. If 100 concurrent requests arrive, only N will process at once, cleanly limiting DB contention and preventing socket exhaustion.
LLM_CONCURRENCY_LIMIT=10

# ==========================================
# 3. SECURITY & SESSION MANAGEMENT (REQUIRED)
# ==========================================
# SESSION_COOKIE_SECURE: Requires HTTPS.
# Purpose: Set to 1 in production to prevent cookie sniffing. Set to 0 in local dev over HTTP.
SESSION_COOKIE_SECURE=1

# SESSION_HMAC_SECRET: Cryptographic secret key.
# Purpose: Validates incoming session cookies and signs user IDs cryptographically to prevent spoofing.
# GENERATE using: `openssl rand -hex 32`
SESSION_HMAC_SECRET="your-secure-random-32-byte-secret"

# ADMIN_API_KEY: Hardcoded bearer token.
# Purpose: Sent in `X-Admin-Key` header to unlock sensitive endpoints like `/ingest` and `/clear`.
ADMIN_API_KEY="your-admin-api-key"

# ALLOWED_ORIGINS: CORS whitelist list.
# Purpose: Comma-separated list of domains allowed to embed the chatbot widget. Use '*' ONLY for testing.
ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# ==========================================
# 4. CHAT ENGINE TUNING (OPTIONAL)
# ==========================================
# HISTORY_MAX_TURNS: Moving window size for conversation memory.
# Purpose: Limits the total token size injected into the LLM context. '2' remembers the last 4 messages (2 human, 2 ai).
HISTORY_MAX_TURNS=2

# RATE_LIMIT_PER_MINUTE: Throttles API abuse.
# Purpose: Caps user interaction speed to prevent bot-spam or denial of wallet attacks on Mistral.
RATE_LIMIT_PER_MINUTE=300

# MAX_UPLOAD_SIZE_MB: Protects ingestion endpoints.
# Purpose: Maximum allowed filesize for document `/ingest`.
MAX_UPLOAD_SIZE_MB=50

# ==========================================
# 5. WHATSAPP BOT INTEGRATION (OPTIONAL)
# ==========================================
# Configure these ONLY if integrating the WhatsApp Business Cloud API webhook.
WA_PHONE_ID="123456789012345"
WA_TOKEN="EAAR9xm..."
WA_VERIFY_TOKEN="your-arbitrary-webhook-verify-token"
WA_TEST_TO_NUMBER="1234567890"

# META_APP_SECRET: Mandatory for production webhooks.
# Purpose: Secures Webhook payload execution by verifying the X-Hub-Signature-256 header.
META_APP_SECRET="meta-app-secret-for-webhook-crypto-verification"

# WA_RATE_LIMIT & WA_RATE_WINDOW: Whatsapp throttler mechanism.
# Purpose: Restricts inbound spam from individual WhatsApp numbers. Defaults to 10 msgs per 60 secs.
WA_RATE_LIMIT=10
WA_RATE_WINDOW=60
