# =============================================================================
# .dockerignore — HuggingFace Spaces / Docker build exclusions
# Keeps the image lean and prevents secrets from being baked in.
# =============================================================================

# ── Python runtime artifacts ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Secrets — NEVER bake .env into a Docker image ────────────────────────────
.env
*.env
*.env.local
prod.example.env
example.env
.example.env

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.github/

# ── Logs & runtime-generated data ────────────────────────────────────────────
logs/
*.log
uploads/

# ── Large user data (uploaded at runtime via /ingest API, not baked in) ──────
data/

# ── Docs, planning & dev notes (not needed in container) ─────────────────────
docs/
scrips/
plan.md
overview.md
prompting-guide.md
architecture_validation.md
README.md

# ── Tests ─────────────────────────────────────────────────────────────────────
tests/

# ── Pre-built wheel artefacts ─────────────────────────────────────────────────
*.whl
wheels/

# ── Local HF cache (populated at runtime — mounted via docker-compose volume) ─
.cache/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
