# =============================================================================
# .vercelignore — Vercel deployment exclusions
# Vercel only needs: src/, static/, requirements.txt
# Everything else is excluded to keep the serverless bundle small.
# =============================================================================

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Local data & logs (runtime only) ─────────────────────────────────────────
data/
logs/
uploads/
*.log

# ── Development & test files ──────────────────────────────────────────────────
tests/
docs/
scrips/

# ── Local HF model cache (not needed on Vercel — no local models) ─────────────
.cache/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.github/

# ── Docker files (not used on Vercel) ────────────────────────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Secrets (set via Vercel Environment Variables dashboard, not files) ───────
.env
*.env
prod.example.env
example.env
.example.env

# ── Planning & docs ───────────────────────────────────────────────────────────
plan.md
overview.md
prompting-guide.md
architecture_validation.md
