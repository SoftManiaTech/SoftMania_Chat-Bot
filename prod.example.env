# ---------------------------------------------------------
# SOFTMANIA CHAT-BOT : STRICT PRODUCTION ENVIRONMENT
# ---------------------------------------------------------
# Copy this file to `.env` on your production server.
# WARNING: NEVER commit your actual `.env` file to version control.

# ==========================================
# 1. DATABASE CONNECTION STRINGS (CRITICAL)
# ==========================================
# IMPORTANT: In production, you MUST use the connection pooling URL (usually ends in -pooler.neon.tech).
# If you use the standard direct connection, high traffic will exhaust the Postgres connection limits and crash the server.
NEON_DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]-pooler.neon.tech/[DBNAME]"

# Your Neo4j AuraDB (Enterprise/Professional) URI
NEO4J_URI="neo4j+s://[YOUR-INSTANCE].databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="[YOUR_SECURE_PASSWORD]"

# ==========================================
# 2. AI MODEL CONFIGURATION (RESILIENCE)
# ==========================================
MISTRAL_API_KEY="sk-[YOUR_PRODUCTION_API_KEY]"

# Depending on your production VRAM vs network latency priorities:
LOCAL_EMBEDDING_MODEL=false

# FAIL-FAST BULKHEAD LIMITS (Required for high traffic)
# These strict limits prevent the "Thundering Herd" database lockup.
LLM_MAX_RETRIES=2               # Max retry attempts for HTTP 429s (used by Tenacity).
LLM_TIMEOUT=5                  # Hard limit for LLM response before aborting.
LLM_CONCURRENCY_LIMIT=5        # Maximum simultaneous requests handled by the server (others get Fast-Failed with 429).

# ==========================================
# 3. SECURITY & SESSION MANAGEMENT (STRICT)
# ==========================================
# Must be 1 in production (requires server to be behind HTTPS/SSL).
SESSION_COOKIE_SECURE=1

# Generate a strong 32-byte cryptographic salt: `openssl rand -hex 32`
# Do NOT use simple passwords here.
# Example: SESSION_HMAC_SECRET="c8a29b4e6d3f8a1c5e7b2d9f4a6c8e1b3d5f7a9c2e4b6d8f1a3c5e7b9d2f4a6c"
SESSION_HMAC_SECRET="[REPLACE_WITH_64_CHAR_HEX_STRING]"

# Protects endpoints like /ingest and /clear.
# Example: ADMIN_API_KEY="sm_live_9f8e7d8c2b5a1f4e3d6c9b8r2a1f0e4d7c"
ADMIN_API_KEY="[GENERATE_A_SECURE_BEARER_TOKEN]"

# CORS Whitelist: MUST explicitly list your live front-end domains.
# NEVER use `*` in production, or external sites will hijack your chatbot.
ALLOWED_ORIGINS="https://www.softmania.in,https://splunklab.softmania.in,https://app.grad2it.in"

# ==========================================
# 4. CHAT ENGINE TUNING
# ==========================================
# Keep chat history token consumption low to reduce Mistral API costs context bloat.
HISTORY_MAX_TURNS=0

# Global Rate Limiting across all APIs to prevent DDoS attacks.
RATE_LIMIT_PER_MINUTE=20
MAX_UPLOAD_SIZE_MB=25

# ==========================================
# 5. WHATSAPP BOT INTEGRATION (PRODUCTION)
# ==========================================
# Use actual business phone ID, permanent system user access token, and strict crypto signatures.
WA_PHONE_ID="[BUSINESS_PHONE_ID]"
WA_TOKEN="[PERMANENT_SYSTEM_USER_ACCESS_TOKEN]"
WA_VERIFY_TOKEN="[SECURE_RANDOM_HANDSHAKE_STRING]"
META_APP_SECRET="[YOUR_META_APP_SECRET_FROM_DASHBOARD]"

# Aggressive rate limit per individual phone number to drop spam bots.
WA_RATE_LIMIT=10
WA_RATE_WINDOW=60
