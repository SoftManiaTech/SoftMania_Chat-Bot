# Networking
PORT=7860
HOST=0.0.0.0

# Database Settings
NEON_DATABASE_URL="postgresql://user:password@endpoint/dbname"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password"

# Embedding and Model Overrides
# Set to 'false' to disable local HuggingFace tokenizer/model downloads and use remote Mistral instead
LOCAL_EMBEDDING_MODEL=false

# Required if LOCAL_EMBEDDING_MODEL=false
MISTRAL_API_KEY="sk-xxxx"

# Session Security
SESSION_HMAC_SECRET="your-secure-random-secret"
SESSION_EXPIRY_HOURS=72

# Enables HTTPS-only secure cookies for session authentication (1 for True, 0 for False)
SESSION_COOKIE_SECURE=1
